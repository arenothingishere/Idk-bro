local COLORS = {
	Record = Color3.fromRGB(220, 50, 50),
	Stop   = Color3.fromRGB(200, 140, 40),
	Step   = Color3.fromRGB(120, 100, 200),
	Save   = Color3.fromRGB(50, 150, 220),
	Play   = Color3.fromRGB(50, 200, 80),
	Reset  = Color3.fromRGB(150, 150, 150),
}

RunService.RenderStepped:Connect(function()
	if not RecorderModule or type(RecorderModule) ~= "table" then return end
	
	local state = RecorderModule:GetState() or "idle"
	StatusLabel.Text = "State: " .. string.upper(state)
	
	-- 根據狀態切換各個按鈕的可點擊性與視覺顏色
	if state == "idle" then
		setButtonState(BtnRecord, true,  COLORS.Record, "⏺ Record")
		setButtonState(BtnStop,   false, COLORS.Stop,   "⏸ Pause")
		setButtonState(BtnBack,   false, COLORS.Step)
		setButtonState(BtnFront,  false, COLORS.Step)
		setButtonState(BtnSave,   false, COLORS.Save)
		setButtonState(BtnPlay,   false, COLORS.Play)
		setButtonState(BtnReset,  false, COLORS.Reset)
		
	elseif state == "recording" then
		setButtonState(BtnRecord, false, COLORS.Record, "⏺ Recording...")
		setButtonState(BtnStop,   true,  COLORS.Stop,   "⏸ Pause (Preview)")
		setButtonState(BtnBack,   false, COLORS.Step)
		setButtonState(BtnFront,  false, COLORS.Step)
		setButtonState(BtnSave,   true,  COLORS.Save) -- 錄製中可直接 Save 結束
		setButtonState(BtnPlay,   false, COLORS.Play)
		setButtonState(BtnReset,  true,  COLORS.Reset)
		
	elseif state == "stopped" then -- Preview Mode (StopActive = true)
		setButtonState(BtnRecord, false, COLORS.Record, "⏺ Record")
		setButtonState(BtnStop,   true,  Color3.fromRGB(220, 180, 50), "▶ Resume Record")
		setButtonState(BtnBack,   true,  COLORS.Step)
		setButtonState(BtnFront,  true,  COLORS.Step)
		setButtonState(BtnSave,   true,  COLORS.Save)
		setButtonState(BtnPlay,   false, COLORS.Play)
		setButtonState(BtnReset,  true,  COLORS.Reset)
		
	elseif state == "saved" then
		setButtonState(BtnRecord, true,  COLORS.Record, "⏺ Re-Record")
		setButtonState(BtnStop,   false, COLORS.Stop,   "⏸ Pause")
		setButtonState(BtnBack,   false, COLORS.Step)
		setButtonState(BtnFront,  false, COLORS.Step)
		setButtonState(BtnSave,   false, COLORS.Save)
		setButtonState(BtnPlay,   true,  COLORS.Play)
		setButtonState(BtnReset,  true,  COLORS.Reset)
		
	elseif state == "playing" then
		setButtonState(BtnRecord, false, COLORS.Record, "⏺ Record")
		setButtonState(BtnStop,   true,  COLORS.Record, "⏹ Stop Playback") -- 播放時 Stop 的含義改變
		setButtonState(BtnBack,   false, COLORS.Step)
		setButtonState(BtnFront,  false, COLORS.Step)
		setButtonState(BtnSave,   false, COLORS.Save)
		setButtonState(BtnPlay,   false, COLORS.Play)
		setButtonState(BtnReset,  true,  COLORS.Reset)
	end
end)

