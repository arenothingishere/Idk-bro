local function shallowCopy(source: { [string]: any }?): { [string]: any }
	local out = {}
	if not source then
		return out
	end
	for k, v in pairs(source) do
		out[k] = v
	end
	return out
end

local function deepCloneAnimList(list: { AnimEntry }?): { AnimEntry }
	local out = {}
	if not list then
		return out
	end
	for i, v in ipairs(list) do
		out[i] = {
			id = v.id,
			weight = v.weight,
		}
	end
	return out
end

local function deepCloneAnimSet(source: { [string]: { AnimEntry } }): { [string]: { AnimEntry } }
	local out = {}
	for name, list in pairs(source) do
		out[name] = deepCloneAnimList(list)
	end
	return out
end

local function priorityToName(priority: Enum.AnimationPriority?): string
	if priority == nil then
		return "Idle"
	end
	for name, enumItem in pairs(PRIORITY_BY_NAME) do
		if enumItem == priority then
			return name
		end
	end
	return "Idle"
end

local function encodeCFrame(cf: CFrame): { [string]: number }
	local x, y, z, r00, r01, r02, r10, r11, r12, r20, r21, r22 = cf:GetComponents()
	return {
		x = x,
		y = y,
		z = z,
		r00 = r00,
		r01 = r01,
		r02 = r02,
		r10 = r10,
		r11 = r11,
		r12 = r12,
		r20 = r20,
		r21 = r21,
		r22 = r22,
	}
end

local function decodeCFrame(payload: { [string]: any }): CFrame
	return CFrame.new(
		tonumber(payload.x) or 0,
		tonumber(payload.y) or 0,
		tonumber(payload.z) or 0,
		tonumber(payload.r00) or 1,
		tonumber(payload.r01) or 0,
		tonumber(payload.r02) or 0,
		tonumber(payload.r10) or 0,
		tonumber(payload.r11) or 1,
		tonumber(payload.r12) or 0,
		tonumber(payload.r20) or 0,
		tonumber(payload.r21) or 0,
		tonumber(payload.r22) or 1
	)
end

local function cframeComponentDelta(a: CFrame, b: CFrame): number
	local ax, ay, az, ar00, ar01, ar02, ar10, ar11, ar12, ar20, ar21, ar22 = a:GetComponents()
	local bx, by, bz, br00, br01, br02, br10, br11, br12, br20, br21, br22 = b:GetComponents()

	return math.max(
		math.abs(ax - bx),
		math.abs(ay - by),
		math.abs(az - bz),
		math.abs(ar00 - br00),
		math.abs(ar01 - br01),
		math.abs(ar02 - br02),
		math.abs(ar10 - br10),
		math.abs(ar11 - br11),
		math.abs(ar12 - br12),
		math.abs(ar20 - br20),
		math.abs(ar21 - br21),
		math.abs(ar22 - br22)
	)
end

local function getPivotOffsetInverse(rootPart: BasePart?): CFrame
	if not rootPart then
		return CFrame.identity
	end

	local ok, pivotOffset = pcall(function()
		return rootPart.PivotOffset
	end)
	if ok and typeof(pivotOffset) == "CFrame" then
		return pivotOffset:Inverse()
	end

	return CFrame.identity
end

