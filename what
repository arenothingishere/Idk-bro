function Recorder:_getTool(): Tool?
	local character = self._character
	if not character then
		return nil
	end

	for _, kid in ipairs(character:GetChildren()) do
		if kid:IsA("Tool") then
			return kid
		end
	end

	return nil
end

function Recorder:_getToolAnim(tool: Tool): StringValue?
	for _, c in ipairs(tool:GetChildren()) do
		if c:IsA("StringValue") and c.Name == "toolanim" then
			return c
		end
	end
	return nil
end

function Recorder:_animateTool()
	if not self._humanoid then
		return
	end

	if self._toolAnimSignal == "None" then
		self:_playToolAnimation(
			"toolnone",
			self._toolTransitionTime,
			self._humanoid,
			Enum.AnimationPriority.Idle
		)
		return
	end

	if self._toolAnimSignal == "Slash" then
		self:_playToolAnimation(
			"toolslash",
			0,
			self._humanoid,
			Enum.AnimationPriority.Action
		)
		return
	end

	if self._toolAnimSignal == "Lunge" then
		self:_playToolAnimation(
			"toollunge",
			0,
			self._humanoid,
			Enum.AnimationPriority.Action
		)
		return
	end
end

function Recorder:_moveSit()
	if not self._rightShoulder or not self._leftShoulder or not self._rightHip or not self._leftHip then
		return
	end

	self._rightShoulder.MaxVelocity = 0.15
	self._leftShoulder.MaxVelocity = 0.15
	self._rightShoulder:SetDesiredAngle(math.pi / 2)
	self._leftShoulder:SetDesiredAngle(-math.pi / 2)
	self._rightHip:SetDesiredAngle(math.pi / 2)
	self._leftHip:SetDesiredAngle(-math.pi / 2)
end

function Recorder:_move(timeNow: number)
	if not self._humanoid then
		return
	end

	local amplitude = 1
	local frequency = 1
	local deltaTime = timeNow - self._lastTick
	self._lastTick = timeNow

	local climbFudge = 0
	local setAngles = false

	if self._jumpAnimTime > 0 then
		self._jumpAnimTime -= deltaTime
	end

	if self._pose == "FreeFall" and self._jumpAnimTime <= 0 then
		self:_playAnimation("fall", self._fallTransitionTime, self._humanoid)
	elseif self._pose == "Seated" then
		self:_playAnimation("sit", 0.5, self._humanoid)
		return
	elseif self._pose == "Running" then
		self:_playAnimation("walk", 0.1, self._humanoid)
	elseif
		self._pose == "Dead"
		or self._pose == "GettingUp"
		or self._pose == "FallingDown"
		or self._pose == "PlatformStanding"
	then
		self:_stopAllAnimations()
		amplitude = 0.1
		frequency = 1
		setAngles = true
	end

	if setAngles and self._rightShoulder and self._leftShoulder and self._rightHip and self._leftHip then
		local desiredAngle = amplitude * math.sin(timeNow * frequency)

		self._rightShoulder:SetDesiredAngle(desiredAngle + climbFudge)
		self._leftShoulder:SetDesiredAngle(desiredAngle - climbFudge)
		self._rightHip:SetDesiredAngle(-desiredAngle)
		self._leftHip:SetDesiredAngle(-desiredAngle)
	end

	local tool = self:_getTool()
	if tool and tool:FindFirstChild("Handle") then
		local animStringValueObject = self:_getToolAnim(tool)

		if animStringValueObject then
			self._toolAnimSignal = animStringValueObject.Value
			animStringValueObject.Parent = nil
			self._toolAnimTime = timeNow + 0.3

			self:_pushEvent("tool_anim_signal", {
				value = self._toolAnimSignal,
				tool = tool.Name,
			})
		end

		if timeNow > self._toolAnimTime then
			self._toolAnimTime = 0
			self._toolAnimSignal = "None"
		end

		self:_animateTool()
	else
		self:_stopToolAnimations()
		self._toolAnimSignal = "None"
		self._toolAnimTime = 0
	end
end

function Recorder:_step(dt: number)
	if self:_isRuntimeSuppressed() then
		return
	end

	if not self._character or not self._humanoid then
		return
	end

	self._simTime += dt
	self:_move(self._simTime)

	if self._state == "recording" then
		self._rootSampleAccumulator += dt
		while self._rootSampleAccumulator >= ROOT_SAMPLE_RATE do
			self._rootSampleAccumulator -= ROOT_SAMPLE_RATE
			self:_recordRootMotion(false)
		end
	end
end

function Recorder:_parseChatEmote(msg: string): string?
	if msg == "/e dance" then
		return DANCES[math.random(1, #DANCES)]
	end
	if string.sub(msg, 1, 3) == "/e " then
		return string.sub(msg, 4)
	end
	if string.sub(msg, 1, 7) == "/emote " then
		return string.sub(msg, 8)
	end
	return nil
end

function Recorder:_hookEmoteInterfaces()
	if LOCAL_PLAYER then
		self._chatConn = LOCAL_PLAYER.Chatted:Connect(function(msg: string)
			if self:_isRuntimeSuppressed() then
				return
			end

			local emote = self:_parseChatEmote(msg)
			if emote then
				self:_playEmote(emote)
			end
		end)
	end

	local bindable = self._moduleScript:FindFirstChild("PlayEmote")
	if bindable and bindable:IsA("BindableFunction") then
		self._playEmoteBindable = bindable
		bindable.OnInvoke = function(emote: string)
			return self:_playEmote(emote)
		end
	end
end

function Recorder:_playEmote(emote: string): (boolean, AnimationTrack?)
	if not self._humanoid then
		return false, nil
	end
	if self:_isRuntimeSuppressed() then
		return false, nil
	end

	if emote == "dance" then
		emote = DANCES[math.random(1, #DANCES)]
	end

	self:_pushTrace("emote_request", {
		emote = emote,
	})

	if self._pose ~= "Standing" then
		return false, nil
	end

	if self._emoteNames[emote] ~= nil then
		local track = self:_playAnimation(emote, 0.1, self._humanoid)
		self:_pushEvent("emote", {
			emote = emote,
		})
		return true, track
	end

	return false, nil
end

function Recorder:_connectHumanoidEvents()
	if not self._humanoid then
		return
	end

	self._runningConn = self._humanoid.Running:Connect(function(speed: number)
		self:_onRunning(speed)
	end)

	self._diedConn = self._humanoid.Died:Connect(function()
		self:_onDied()
	end)

	self._jumpingConn = self._humanoid.Jumping:Connect(function(active: boolean)
		if active then
			self:_onJumping()
		end
	end)

	self._climbingConn = self._humanoid.Climbing:Connect(function(speed: number)
		self:_onClimbing(speed)
	end)

	self._gettingUpConn = self._humanoid.GettingUp:Connect(function()
		self:_onGettingUp()
	end)

	self._freeFallConn = self._humanoid.FreeFalling:Connect(function(active: boolean)
		if active then
			self:_onFreeFall()
		end
	end)

	self._fallingDownConn = self._humanoid.FallingDown:Connect(function(active: boolean)
		if active then
			self:_onFallingDown()
		end
	end)

	self._seatedConn = self._humanoid.Seated:Connect(function(active: boolean)
		if active then
			self:_onSeated()
		end
	end)

	self._platformStandingConn = self._humanoid.PlatformStanding:Connect(function(active: boolean)
		if active then
			self:_onPlatformStanding()
		end
	end)

	self._swimmingConn = self._humanoid.Swimming:Connect(function(speed: number)
		self:_onSwimming(speed)
	end)

	self._stateChangedConn = self._humanoid.StateChanged:Connect(function(oldState, newState)
		if self:_isRuntimeSuppressed() then
			return
		end

		self:_pushTrace("state_changed", {
			from = tostring(oldState),
			to = tostring(newState),
		})

		if newState == Enum.HumanoidStateType.Dead then
			self:_onDied()
		elseif newState == Enum.HumanoidStateType.Jumping then
			self:_onJumping()
		elseif newState == Enum.HumanoidStateType.Freefall then
			self:_onFreeFall()
		elseif newState == Enum.HumanoidStateType.Climbing then
			self:_setPose("Climbing", { value = "Climbing" })
		elseif newState == Enum.HumanoidStateType.Seated then
			self:_onSeated()
		elseif newState == Enum.HumanoidStateType.GettingUp then
			self:_onGettingUp()
		elseif newState == Enum.HumanoidStateType.FallingDown then
			self:_onFallingDown()
		elseif newState == Enum.HumanoidStateType.PlatformStanding then
			self:_onPlatformStanding()
		end
	end)
end

function Recorder:_disconnectAll()
	local conns = {
		self._runningConn,
		self._diedConn,
		self._jumpingConn,
		self._climbingConn,
		self._gettingUpConn,
		self._freeFallConn,
		self._fallingDownConn,
		self._seatedConn,
		self._platformStandingConn,
		self._swimmingConn,
		self._stateChangedConn,
		self._childAddedConn,
		self._childRemovedConn,
		self._heartbeatConn,
		self._chatConn,
	}

	for _, conn in ipairs(conns) do
		if conn then
			conn:Disconnect()
		end
	end

	self._runningConn = nil
	self._diedConn = nil
	self._jumpingConn = nil
	self._climbingConn = nil
	self._gettingUpConn = nil
	self._freeFallConn = nil
	self._fallingDownConn = nil
	self._seatedConn = nil
	self._platformStandingConn = nil
	self._swimmingConn = nil
	self._stateChangedConn = nil
	self._childAddedConn = nil
	self._childRemovedConn = nil
	self._heartbeatConn = nil
	self._chatConn = nil

	if self._playEmoteBindable then
		self._playEmoteBindable.OnInvoke = nil
		self._playEmoteBindable = nil
	end
end


function Recorder:_setState(newState: string)
	self._state = newState
	self.Status = newState
end

function Recorder:_bindCharacter(character: Model)
	self:_disconnectAll()
	self:_disablePlaybackPhysics()
	self:_disableStopPhysics(false)
	self:_stopAllAnimations(true, 0)
	self:_stopToolAnimations(true)
	self:_restoreDefaultAnimate()

	self._character = character
	self._torso = character:WaitForChild("Torso") :: BasePart
	self._rootPart = character:WaitForChild("HumanoidRootPart") :: BasePart
	self._rightShoulder = self._torso:WaitForChild("Right Shoulder") :: Motor6D
	self._leftShoulder = self._torso:WaitForChild("Left Shoulder") :: Motor6D
	self._rightHip = self._torso:WaitForChild("Right Hip") :: Motor6D
	self._leftHip = self._torso:WaitForChild("Left Hip") :: Motor6D
	self._neck = self._torso:WaitForChild("Neck") :: Motor6D
	self._humanoid = character:WaitForChild("Humanoid") :: Humanoid
	self._animator = self._humanoid:FindFirstChildOfClass("Animator")

	self:_disableDefaultAnimate()

	if self._animator then
		for _, track in ipairs(self._animator:GetPlayingAnimationTracks()) do
			track:Stop(0)
			track:Destroy()
		end
	end

	for name, fileList in pairs(self._animNames) do
		self:_configureAnimationSet(name, fileList)
	end

	self._childAddedConn = self._moduleScript.ChildAdded:Connect(function(child: Instance)
		self:_scriptChildModified(child)
	end)

	self._childRemovedConn = self._moduleScript.ChildRemoved:Connect(function(child: Instance)
		self:_scriptChildModified(child)
	end)

	self:_connectHumanoidEvents()
	self:_hookEmoteInterfaces()

	self._heartbeatConn = RunService.Heartbeat:Connect(function(dt: number)
		self:_step(dt)
	end)

	self._pose = "Standing"
	self._simTime = 0
	self._lastTick = 0
	self._toolAnimSignal = "None"
	self._toolAnimTime = 0
	self._playing = false
	self._stopActive = false
	self._rootSampleAccumulator = 0
	self._lastRecordedRootCFrame = nil
	self._playbackMotionIndex = 1
	self._stopPreviewFrame = 1
	self._stopPreviewTime = 0
	self._stopResumeTruncateTime = nil

	if self._humanoid then
		self:_playAnimation("idle", 0.1, self._humanoid)
	end

	self:_setState("idle")
	return self
end

function Recorder:_getLocalCharacter(): Model?
	if not LOCAL_PLAYER then
		return nil
	end

	local character = LOCAL_PLAYER.Character
	if character and character.Parent then
		return character
	end

	local ok, loadedCharacter = pcall(function()
		return LOCAL_PLAYER.CharacterAdded:Wait()
	end)

	if ok and loadedCharacter and loadedCharacter.Parent then
		return loadedCharacter
	end

	return nil
end

function Recorder:_ensureCharacterBound(): boolean
	local character = self:_getLocalCharacter()
	if not character then
		return false
	end

	local humanoid = self._humanoid
	local rootPart = self._rootPart

	local needsRebind = (
		self._character ~= character
		or humanoid == nil
		or humanoid.Parent ~= character
		or rootPart == nil
		or rootPart.Parent ~= character
		or self._heartbeatConn == nil
	)

	if needsRebind then
		self:_bindCharacter(character)
	end

	return self._character ~= nil and self._humanoid ~= nil and self._rootPart ~= nil
end

function Recorder:_stopRecordingInternal()
	if self._state ~= "recording" and not (self._state == "stopped" and self._stopActive) then
		return false, "not_recording"
	end

	if self._state == "stopped" and self._stopActive then
		local finalTime = self._stopResumeTruncateTime or self._stopPreviewTime or 0
		self:_truncateLiveSessionAtTime(finalTime)
		self._recordStartClock = os.clock() - finalTime
		self._rootSampleAccumulator = 0
		self._lastRecordedRootCFrame = nil
		self:_setState("recording")
		self:_recordRootMotion(true)
		self._stopActive = false
		if self._currentAnimTrack then
			self._currentAnimTrack:AdjustSpeed(self._stopStoredMainSpeed)
			self._currentAnimSpeed = self._stopStoredMainSpeed
		end
		if self._toolAnimTrack then
			self._toolAnimTrack:AdjustSpeed(self._stopStoredToolSpeed)
		end
		self:_disableStopPhysics(false)
	end

	self:_recordRootMotion(true)
	self:_pushEvent("session_stop", {
		finalPose = self._pose,
		currentAnim = self._currentAnim,
		currentToolAnim = self._currentToolAnimName,
	})
	self:_setState("stopped")
	return true
end

function Recorder:_stopPlaybackInternal()
	if self._state ~= "playing" then
		return false, "not_playing"
	end

	self._playing = false
	self._playToken += 1
	self:_setState("saved")

	self:_disablePlaybackPhysics()
	self:_stopAllAnimations(true, 0)
	self:_stopToolAnimations(true)

	if self._humanoid then
		self:_playAnimation("idle", 0.1, self._humanoid)
		self._pose = "Standing"
	end

	return true
end

function Recorder:_clearSessionData()
	self._live = nil
	self._savedSession = nil
	self._savedDecoded = nil
	self._recordStartClock = 0
	self._eventSeq = 0
	self._rootSampleAccumulator = 0
	self._lastRecordedRootCFrame = nil
	self._playbackMotionIndex = 1
	self._stopActive = false
	self._stopPreviewFrame = 1
	self._stopPreviewTime = 0
	self._stopResumeTruncateTime = nil
	self._stopStoredLinearVelocity = Vector3.zero
	self._stopStoredAngularVelocity = Vector3.zero
	self._stopStoredMainSpeed = 1.0
	self._stopStoredToolSpeed = 1.0
end

function Recorder:Record()
	if self._state == "playing" then
		return false, "playing"
	end
	if self._state == "recording" then
		return false, "already_recording"
	end
	if self._state == "stopped" and self._stopActive then
		return false, "stop_active"
	end
	if not self:_ensureCharacterBound() then
		return false, "character_not_ready"
	end

	self:_disablePlaybackPhysics()
	self:_disableStopPhysics(false)
	self:_disableDefaultAnimate()
	self._savedSession = nil
	self._savedDecoded = nil

	self._live = {
		meta = {
			rig = "R6",
			scale = self:_getRigScale(),
			startedAt = os.clock(),
			replayVersion = 4,
			module = "HumanoidAnimRecorder",
			rootMotion = true,
			rootSampleRate = ROOT_SAMPLE_RATE,
		},
		animationSets = self:_snapshotResolvedAnimationSets(),
		events = {},
		trace = {},
	}

	self._recordStartClock = os.clock()
	self._eventSeq = 0
	self._stopActive = false
	self:_setState("recording")
	self._rootSampleAccumulator = 0
	self._lastRecordedRootCFrame = nil
	self._stopPreviewFrame = 1
	self._stopPreviewTime = 0
	self._stopResumeTruncateTime = nil

	self:_pushEvent("session_start", {
		initialPose = self._pose,
		currentAnim = self._currentAnim,
		currentToolAnim = self._currentToolAnimName,
	})

	self:_recordCurrentAnimationState()
	self:_recordRootMotion(true)

	return true
end

function Recorder:Stop()
	if self._state == "recording" then
		return self:_enterStopMode()
	end

	if self._state == "stopped" and self._stopActive then
		return self:_exitStopMode()
	end

	if self._state == "playing" then
		return self:_stopPlaybackInternal()
	end

	return false, "nothing_to_stop"
end

function Recorder:goBack(frameCount: number)
	local delta = math.floor(math.abs(tonumber(frameCount) or 0))
	if delta <= 0 then
		return false, "invalid_frame"
	end

	return self:_goStopFrame(-delta)
end

function Recorder:goFront(frameCount: number)
	local delta = math.floor(math.abs(tonumber(frameCount) or 0))
	if delta <= 0 then
		return false, "invalid_frame"
	end

	return self:_goStopFrame(delta)
end

function Recorder:Save()
	if self._state == "recording" or (self._state == "stopped" and self._stopActive) then
		local ok, reason = self:_stopRecordingInternal()
		if not ok then
			return false, reason
		end
	end

	if self._state == "saved" and self._savedSession then
		return true, self._savedSession
	end

	if self._state ~= "stopped" or not self._live then
		return false, "no_recording_data"
	end

	self._savedSession = HttpService:JSONEncode(self._live)
	self._savedDecoded = self._live
	self:_setState("saved")
	return true, self._savedSession
end

function Recorder:_loadSavedString(savedString: string)
	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(savedString)
	end)

	if not ok then
		return false, "decode_failed"
	end

	self._savedSession = savedString
	self._savedDecoded = decoded
	self:_setState("saved")
	return true, decoded
end

function Recorder:_parsePriority(priorityText: any): Enum.AnimationPriority
	if typeof(priorityText) ~= "string" then
		return Enum.AnimationPriority.Idle
	end
	return PRIORITY_BY_NAME[priorityText] or Enum.AnimationPriority.Idle
end

function Recorder:_waitUntilPlaybackOffset(startClock: number, targetOffset: number, token: number)
	while self._playing and self._playToken == token do
		local elapsed = os.clock() - startClock
		local remaining = targetOffset - elapsed
		if remaining <= 0 then
			break
		end
		RunService.Heartbeat:Wait()
	end
end

function Recorder:Play(savedString: string?)
	if self._state == "recording" or (self._state == "stopped" and self._stopActive) then
		local okStop, reason = self:_stopRecordingInternal()
		if not okStop then
			return false, reason
		end
	end

	if self._state == "playing" then
		return false, "already_playing"
	end

	if not self:_ensureCharacterBound() then
		return false, "character_not_ready"
	end

	if savedString then
		local okLoad = self:_loadSavedString(savedString)
		if not okLoad then
			return false, "decode_failed"
		end
	elseif self._state == "stopped" and self._live and not self._savedSession then
		local okSave = self:Save()
		if not okSave then
			return false, "save_failed"
		end
	end

	if not self._savedSession then
		return false, "no_saved_data"
	end
	if not self._humanoid then
		return false, "character_not_ready"
	end

	local session = self._savedDecoded
	if session == nil then
		local ok, decoded = pcall(function()
			return HttpService:JSONDecode(self._savedSession :: string)
		end)
		if not ok then
			return false, "decode_failed"
		end
		session = decoded
		self._savedDecoded = decoded
	end

	local replayEvents, rootMotionEvents = self:_splitReplayEvents(session)
	local initialRootCFrame = if #rootMotionEvents > 0 then decodeCFrame(rootMotionEvents[1]) else nil

	self._playing = true
	self:_setState("playing")
	self._playToken += 1
	local myToken = self._playToken

	task.spawn(function()
		self:_disablePlaybackPhysics()
		self:_disableStopPhysics(false)
		self:_stopAllAnimations(true, 0)
		self:_stopToolAnimations(true)

		if initialRootCFrame then
			if self._character then
				self._character:PivotTo(initialRootCFrame)
			elseif self._rootPart then
				self._rootPart:PivotTo(initialRootCFrame)
			end

			self:_enablePlaybackPhysics(initialRootCFrame)
			self:_applyPlaybackRootMotion(initialRootCFrame)
		end

		local startClock = os.clock()

		if #rootMotionEvents > 0 then
			task.spawn(function()
				while self._playing and self._playToken == myToken do
					local elapsed = os.clock() - startClock
					local sampled = self:_sampleRootMotion(rootMotionEvents, elapsed)
					if sampled then
						self:_applyPlaybackRootMotion(sampled)
					end
					RunService.Heartbeat:Wait()
				end
			end)
		end

		for _, ev in ipairs(replayEvents) do
			if not self._playing or self._playToken ~= myToken then
				break
			end

			self:_waitUntilPlaybackOffset(startClock, tonumber(ev.t) or 0, myToken)

			if not self._playing or self._playToken ~= myToken then
				break
			end

			local kind = ev.kind

			if kind == "session_start" then
				self._pose = ev.initialPose or "Standing"

			elseif kind == "pose" then
				self._pose = ev.value or self._pose

			elseif kind == "speed" then
				if ev.target == "main" then
					self:_setAnimationSpeed(tonumber(ev.value) or 1, true)
				end

			elseif kind == "playAnimation" then
				self:_playAnimation(
					ev.animName or "idle",
					tonumber(ev.transitionTime) or 0,
					self._humanoid :: Humanoid,
					ev.animId,
					true
				)
				if ev.speed ~= nil then
					self:_setAnimationSpeed(tonumber(ev.speed) or 1, true)
				end

			elseif kind == "stopAnimation" then
				self:_stopAllAnimations(true, tonumber(ev.transitionTime) or 0)

			elseif kind == "playToolAnimation" then
				self._toolAnimSignal = ev.signal or self._toolAnimSignal
				self:_playToolAnimation(
					ev.animName or "toolnone",
					tonumber(ev.transitionTime) or 0,
					self._humanoid :: Humanoid,
					self:_parsePriority(ev.priority),
					ev.animId,
					true
				)

			elseif kind == "stopToolAnimation" then
				self:_stopToolAnimations(true)

			elseif kind == "tool_anim_signal" then
				self._toolAnimSignal = ev.value or "None"

			elseif kind == "session_stop" then
				-- no-op, for audit only

			elseif kind == "emote" then
				-- no-op, because actual playback is driven by playAnimation events
			end
		end

		if self._playToken == myToken then
			self._playing = false
			self:_setState("saved")

			self:_disablePlaybackPhysics()
			self:_stopToolAnimations(true)

			if self._humanoid then
				self:_playAnimation("idle", 0.1, self._humanoid)
				self._pose = "Standing"
			end
		end
	end)

	return true
end

function Recorder:Reset()
	self._playing = false
	self._playToken += 1
	self._stopActive = false

	self:_disconnectAll()
	self:_disablePlaybackPhysics()
	self:_disableStopPhysics(false)
	self:_stopAllAnimations(true, 0)
	self:_stopToolAnimations(true)
	self:_restoreDefaultAnimate()

	self._character = nil
	self._humanoid = nil
	self._torso = nil
	self._rootPart = nil
	self._rightShoulder = nil
	self._leftShoulder = nil
	self._rightHip = nil
	self._leftHip = nil
	self._neck = nil
	self._animator = nil

	self._pose = "Standing"
	self._toolAnimSignal = "None"
	self._toolAnimTime = 0
	self._simTime = 0
	self._lastTick = 0
	self._stopPreviewFrame = 1
	self._stopPreviewTime = 0
	self._stopResumeTruncateTime = nil
	self:_clearSessionData()

	self:_setState("idle")
	return true
end

local singleton = Recorder.new()
singleton:_setState("idle")
return singleton

	
