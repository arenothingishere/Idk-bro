local function setButtonState(btn, isEnabled, activeColor, newText)
	if newText then
		btn.Text = newText
	end
	
	btn.Interactable = isEnabled -- Roblox 內建，關閉後無法點擊且會有微微暗化
	
	if isEnabled then
		btn.BackgroundColor3 = activeColor
		btn.BackgroundTransparency = 0
		btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	else
		-- 視覺變灰暗
		local h, s, v = Color3.toHSV(activeColor)
		btn.BackgroundColor3 = Color3.fromHSV(h, s * 0.4, v * 0.4)
		btn.BackgroundTransparency = 0.5
		btn.TextColor3 = Color3.fromRGB(180, 180, 180)
	end
end

