function Recorder:_beginAtomicAction(actionName: string): (boolean, string?)
	if self._apiBusy then
		return false, if self._apiBusyName ~= "" then ("busy_" .. self._apiBusyName) else "busy"
	end

	self._apiBusy = true
	self._apiBusyName = actionName
	return true, nil
end

function Recorder:_endAtomicAction(actionName: string?)
	if actionName == nil or self._apiBusyName == actionName then
		self._apiBusy = false
		self._apiBusyName = ""
	end
end

function Recorder:_runAtomicAction(actionName: string, callback)
	local ok, reason = self:_beginAtomicAction(actionName)
	if not ok then
		return false, reason
	end

	local success, resultA, resultB, resultC = pcall(callback)
	self:_endAtomicAction(actionName)

	if not success then
		warn("[HumanoidAnimRecorder] action failed:", actionName, resultA)
		return false, "internal_error"
	end

	return resultA, resultB, resultC
end

function Recorder:_isRuntimeSuppressed(): boolean
	return self._playing or self._stopActive
end

function Recorder:_getRigScale(): number
	local character = self._character
	if not character then
		return 1
	end

	local ok, scale = pcall(function()
		return character:GetScale()
	end)
	if ok and typeof(scale) == "number" and scale > 0 then
		return scale
	end

	return 1
end

function Recorder:_disableDefaultAnimate()
	local character = self._character
	if not character then
		return
	end

	local animate = character:FindFirstChild("Animate")
	if animate and (animate:IsA("LocalScript") or animate:IsA("Script")) then
		if not animate.Disabled then
			self._disabledAnimateScript = animate
			animate.Disabled = true
		end
	end
end

function Recorder:_restoreDefaultAnimate()
	local animate = self._disabledAnimateScript
	if animate and animate.Parent then
		animate.Disabled = false
	end
	self._disabledAnimateScript = nil
end

function Recorder:_destroyAnimationObject(anim: Animation?, isTransient: boolean)
	if anim and isTransient then
		anim:Destroy()
	end
end

function Recorder:_makeTempAnimation(animName: string, animId: string): PoolItem
	local anim = Instance.new("Animation")
	anim.Name = animName
	anim.AnimationId = animId
	return {
		anim = anim,
		weight = 1,
		transient = true,
	}
end

function Recorder:_log(kind: string, payload: { [string]: any }?, replayRelevant: boolean)
	if self._state ~= "recording" or self._playing or not self._live then
		return
	end

	local event = shallowCopy(payload)
	self._eventSeq += 1
	event.seq = self._eventSeq
	event.kind = kind
	event.t = os.clock() - self._recordStartClock
	event.pose = self._pose
	event.state = self._state

	table.insert(self._live.trace, shallowCopy(event) :: SessionEvent)
	if replayRelevant then
		table.insert(self._live.events, event :: SessionEvent)
	end
end

function Recorder:_pushEvent(kind: string, payload: { [string]: any }?)
	self:_log(kind, payload, true)
end

function Recorder:_pushTrace(kind: string, payload: { [string]: any }?)
	self:_log(kind, payload, false)
end

function Recorder:_snapshotResolvedAnimationSets(): { [string]: { AnimEntry } }
	local out = {}
	for name, pool in pairs(self._animTable) do
		local list = {}
		for i = 1, pool.count do
			local item = pool[i]
			if item and item.anim then
				table.insert(list, {
					id = item.anim.AnimationId,
					weight = item.weight,
				})
			end
		end
		out[name] = list
	end
	return out
end

function Recorder:_configureAnimationSet(name: string, fileList: { AnimEntry })
	local animTable = self._animTable
	local old = animTable[name]
	if old then
		for _, connection in ipairs(old.connections) do
			connection:Disconnect()
		end
	end

	animTable[name] = {
		count = 0,
		totalWeight = 0,
		connections = {},
	} :: any

	local config = self._moduleScript:FindFirstChild(name)
	if config then
		table.insert(animTable[name].connections, config.ChildAdded:Connect(function()
			self:_configureAnimationSet(name, fileList)
		end))
		table.insert(animTable[name].connections, config.ChildRemoved:Connect(function()
			self:_configureAnimationSet(name, fileList)
		end))

		local idx = 1
		for _, childPart in ipairs(config:GetChildren()) do
			if childPart:IsA("Animation") then
				table.insert(animTable[name].connections, childPart.Changed:Connect(function()
					self:_configureAnimationSet(name, fileList)
				end))

				animTable[name][idx] = {}
				animTable[name][idx].anim = childPart

				local weightObject = childPart:FindFirstChild("Weight")
				if weightObject and weightObject:IsA("IntValue") then
					animTable[name][idx].weight = weightObject.Value
				else
					animTable[name][idx].weight = 1
				end

				animTable[name].count += 1
				animTable[name].totalWeight += animTable[name][idx].weight
				idx += 1
			end
		end
	end

	if animTable[name].count <= 0 then
		for idx, animEntry in ipairs(fileList) do
			local anim = Instance.new("Animation")
			anim.Name = name
			anim.AnimationId = animEntry.id

			animTable[name][idx] = {
				anim = anim,
				weight = animEntry.weight,
				transient = false,
			}
			animTable[name].count += 1
			animTable[name].totalWeight += animEntry.weight
		end
	end
end

function Recorder:_scriptChildModified(child: Instance)
	local fileList = self._animNames[child.Name]
	if fileList then
		self:_configureAnimationSet(child.Name, fileList)
	end
end

function Recorder:_chooseAnimation(animName: string, forcedAnimId: string?): (PoolItem?, AnimPool?)
	local pool = self._animTable[animName]
	if not forcedAnimId then
		if not pool or pool.count <= 0 then
			return nil, nil
		end

		local roll = math.random(1, pool.totalWeight)
		local idx = 1
		while idx <= pool.count and roll > pool[idx].weight do
			roll -= pool[idx].weight
			idx += 1
		end
		return pool[idx], pool
	end

	if pool then
		for i = 1, pool.count do
			local item = pool[i]
			if item and item.anim and item.anim.AnimationId == forcedAnimId then
				return item, pool
			end
		end
	end

	return self:_makeTempAnimation(animName, forcedAnimId), pool
end

function Recorder:_stopAllAnimations(silent: boolean?, transitionTime: number?): string
	local oldAnim = self._currentAnim

	if self._emoteNames[oldAnim] ~= nil and self._emoteNames[oldAnim] == false then
		oldAnim = "idle"
	end

	local hadTrack = self._currentAnimTrack ~= nil

	self._currentAnim = ""
	if self._currentAnimKeyframeHandler then
		self._currentAnimKeyframeHandler:Disconnect()
		self._currentAnimKeyframeHandler = nil
	end

	if self._currentAnimTrack then
		self._currentAnimTrack:Stop(transitionTime or 0)
		self._currentAnimTrack:Destroy()
		self._currentAnimTrack = nil
	end

	self:_destroyAnimationObject(self._currentAnimInstance, self._currentAnimIsTransient)
	self._currentAnimInstance = nil
	self._currentAnimIsTransient = false
	self._currentAnimSpeed = 1.0

	if hadTrack and not silent then
		self:_pushEvent("stopAnimation", {
			animName = oldAnim,
			transitionTime = transitionTime or 0,
		})
	end

	return oldAnim
end

function Recorder:_stopToolAnimations(silent: boolean?): string
	local oldAnim = self._currentToolAnimName
	local hadTrack = self._toolAnimTrack ~= nil

	if self._currentToolAnimKeyframeHandler then
		self._currentToolAnimKeyframeHandler:Disconnect()
		self._currentToolAnimKeyframeHandler = nil
	end

	if self._toolAnimTrack then
		self._toolAnimTrack:Stop()
		self._toolAnimTrack:Destroy()
		self._toolAnimTrack = nil
	end

	self:_destroyAnimationObject(self._toolAnimInstance, self._currentToolAnimIsTransient)
	self._toolAnimInstance = nil
	self._currentToolAnimIsTransient = false
	self._currentToolAnimName = ""

	if hadTrack and not silent then
		self:_pushEvent("stopToolAnimation", {
			animName = oldAnim,
		})
	end

	return oldAnim
end

function Recorder:_setAnimationSpeed(speed: number, silent: boolean?)
	if speed == self._currentAnimSpeed then
		return
	end

	self._currentAnimSpeed = speed
	if self._currentAnimTrack then
		self._currentAnimTrack:AdjustSpeed(speed)
	end

	if not silent then
		self:_pushEvent("speed", {
			target = "main",
			value = speed,
			animName = self._currentAnim,
		})
	end
end

function Recorder:_playAnimation(
	animName: string,
	transitionTime: number,
	humanoid: Humanoid,
	forcedAnimId: string?,
	silent: boolean?
): (AnimationTrack?, boolean)
	local selected, pool = self:_chooseAnimation(animName, forcedAnimId)
	if not selected or not selected.anim then
		return nil, false
	end

	local anim = selected.anim
	local switched = anim ~= self._currentAnimInstance

	if switched or forcedAnimId ~= nil or self._currentAnim ~= animName then
		self:_pushTrace("playAnimation_request", {
			animName = animName,
			animId = anim.AnimationId,
			transitionTime = transitionTime,
			switch = switched,
			forced = forcedAnimId ~= nil,
		})
	end

	if switched then
		if self._currentAnimTrack then
			self._currentAnimTrack:Stop(transitionTime)
			self._currentAnimTrack:Destroy()
			self._currentAnimTrack = nil
		end

		self:_destroyAnimationObject(self._currentAnimInstance, self._currentAnimIsTransient)
		self._currentAnimInstance = nil
		self._currentAnimIsTransient = false
		self._currentAnimSpeed = 1.0

		self._currentAnimTrack = humanoid:LoadAnimation(anim)
		self._currentAnimTrack.Priority = Enum.AnimationPriority.Core
		self._currentAnimTrack:Play(transitionTime)

		self._currentAnim = animName
		self._currentAnimInstance = anim
		self._currentAnimIsTransient = selected.transient == true

		if self._currentAnimKeyframeHandler then
			self._currentAnimKeyframeHandler:Disconnect()
		end
		self._currentAnimKeyframeHandler = self._currentAnimTrack.KeyframeReached:Connect(function(frameName: string)
			self:_keyFrameReachedFunc(frameName)
		end)

		if not silent then
			self:_pushEvent("playAnimation", {
				animName = animName,
				animId = anim.AnimationId,
				weightPool = if pool then self:_snapshotResolvedAnimationSets()[animName] else { { id = anim.AnimationId, weight = 1 } },
				chosenWeight = selected.weight,
				transitionTime = transitionTime,
				speed = self._currentAnimSpeed,
				priority = "Core",
				looped = (self._emoteNames[animName] == true),
			})
		end
	end

	return self._currentAnimTrack, switched
end

function Recorder:_playToolAnimation(
	animName: string,
	transitionTime: number,
	humanoid: Humanoid,
	priority: Enum.AnimationPriority?,
	forcedAnimId: string?,
	silent: boolean?
): (AnimationTrack?, boolean)
	local selected, pool = self:_chooseAnimation(animName, forcedAnimId)
	if not selected or not selected.anim then
		return nil, false
	end

	local anim = selected.anim
	local switched = anim ~= self._toolAnimInstance

	if switched or forcedAnimId ~= nil or self._currentToolAnimName ~= animName then
		self:_pushTrace("playToolAnimation_request", {
			animName = animName,
			animId = anim.AnimationId,
			transitionTime = transitionTime,
			switch = switched,
			forced = forcedAnimId ~= nil,
			priority = priorityToName(priority),
		})
	end

	if switched then
		if self._toolAnimTrack then
			self._toolAnimTrack:Stop()
			self._toolAnimTrack:Destroy()
			self._toolAnimTrack = nil
			transitionTime = 0
		end

		self:_destroyAnimationObject(self._toolAnimInstance, self._currentToolAnimIsTransient)
		self._toolAnimInstance = nil
		self._currentToolAnimIsTransient = false

		self._toolAnimTrack = humanoid:LoadAnimation(anim)
		if priority then
			self._toolAnimTrack.Priority = priority
		end
		self._toolAnimTrack:Play(transitionTime)

		self._currentToolAnimName = animName
		self._toolAnimInstance = anim
		self._currentToolAnimIsTransient = selected.transient == true

		if self._currentToolAnimKeyframeHandler then
			self._currentToolAnimKeyframeHandler:Disconnect()
		end
		self._currentToolAnimKeyframeHandler = self._toolAnimTrack.KeyframeReached:Connect(function(frameName: string)
			self:_toolKeyFrameReachedFunc(frameName)
		end)

		if not silent then
			self:_pushEvent("playToolAnimation", {
				animName = animName,
				animId = anim.AnimationId,
				weightPool = if pool then self:_snapshotResolvedAnimationSets()[animName] else { { id = anim.AnimationId, weight = 1 } },
				chosenWeight = selected.weight,
				transitionTime = transitionTime,
				priority = priorityToName(priority),
				speed = 1,
				signal = self._toolAnimSignal,
			})
		end
	end

	return self._toolAnimTrack, switched
end

function Recorder:_keyFrameReachedFunc(frameName: string)
	if self._playing then
		return
	end

	self:_pushTrace("keyframe", {
		animName = self._currentAnim,
		frame = frameName,
	})

	if frameName == "End" then
		local repeatAnim = self._currentAnim
		if self._emoteNames[repeatAnim] ~= nil and self._emoteNames[repeatAnim] == false then
			repeatAnim = "idle"
		end

		local animSpeed = self._currentAnimSpeed
		if self._humanoid then
			self:_playAnimation(repeatAnim, 0, self._humanoid)
			self:_setAnimationSpeed(animSpeed)
		end
	end
end

function Recorder:_toolKeyFrameReachedFunc(frameName: string)
	if self._playing then
		return
	end

	self:_pushTrace("tool_keyframe", {
		animName = self._currentToolAnimName,
		frame = frameName,
	})

	if frameName == "End" and self._humanoid then
		self:_playToolAnimation(
			self._currentToolAnimName,
			0,
			self._humanoid,
			Enum.AnimationPriority.Idle
		)
	end
end

function Recorder:_setPose(newPose: string, payload: { [string]: any }?)
	if self._pose == newPose then
		return
	end
	self._pose = newPose
	self:_pushEvent("pose", shallowCopy(payload or {
		value = newPose,
	}))
end

function Recorder:_traceHumanoidSignal(signalName: string, payload: { [string]: any }?)
	self:_pushTrace("humanoid_signal", shallowCopy(payload or {
		name = signalName,
	}))
end

function Recorder:_getRootMotionCFrame(): CFrame?
	local rootPart = self._rootPart
	if rootPart then
		return rootPart:GetPivot()
	end

	local humanoid = self._humanoid
	if humanoid and humanoid.RootPart then
		return humanoid.RootPart:GetPivot()
	end

	local character = self._character
	if character then
		return character:GetPivot()
	end

	return nil
end

function Recorder:_pivotToRootPartCFrame(targetPivot: CFrame): CFrame
	return targetPivot * getPivotOffsetInverse(self._rootPart)
end

function Recorder:_applyImmediateRootMotion(targetPivot: CFrame, zeroVelocity: boolean?)
	local rootPart = self._rootPart
	if rootPart and rootPart.Parent then
		rootPart:PivotTo(targetPivot)
		if zeroVelocity then
			rootPart.AssemblyLinearVelocity = Vector3.zero
			rootPart.AssemblyAngularVelocity = Vector3.zero
		end
		return
	end

	local character = self._character
	if character and character.Parent then
		character:PivotTo(targetPivot)
	end
end

function Recorder:_estimateRootMotionVelocityAtTime(rootMotionEvents: { any }, elapsed: number): (Vector3, Vector3)
	local count = #rootMotionEvents
	if count <= 1 then
		return Vector3.zero, Vector3.zero
	end

	local prevIndex = 1
	while prevIndex < count and elapsed > (tonumber(rootMotionEvents[prevIndex + 1].t) or 0) do
		prevIndex += 1
	end

	local nextIndex = math.clamp(prevIndex + 1, 1, count)
	if nextIndex == prevIndex then
		prevIndex = math.max(prevIndex - 1, 1)
	end

	local prevFrame = rootMotionEvents[prevIndex]
	local nextFrame = rootMotionEvents[nextIndex]
	if not prevFrame or not nextFrame or prevFrame == nextFrame then
		return Vector3.zero, Vector3.zero
	end

	local prevTime = tonumber(prevFrame.t) or 0
	local nextTime = tonumber(nextFrame.t) or prevTime
	local dt = nextTime - prevTime
	if dt <= 0 then
		return Vector3.zero, Vector3.zero
	end

	local prevCFrame = decodeCFrame(prevFrame)
	local nextCFrame = decodeCFrame(nextFrame)
	local linearVelocity = (nextCFrame.Position - prevCFrame.Position) / dt

	local delta = prevCFrame:ToObjectSpace(nextCFrame)
	local axis, angle = delta:ToAxisAngle()
	local angularVelocity = Vector3.zero
	if axis.Magnitude > 0 and math.abs(angle) > 0.000001 then
		angularVelocity = axis * (angle / dt)
	end

	return linearVelocity, angularVelocity
end

function Recorder:_hasRootMotionChanged(rootCf: CFrame, force: boolean?): boolean
	if force or not self._lastRecordedRootCFrame then
		return true
	end

	return cframeComponentDelta(self._lastRecordedRootCFrame, rootCf) > ROOT_SAMPLE_EPSILON
end

function Recorder:_recordCurrentAnimationState()
	if self._state ~= "recording" or self._playing or not self._humanoid then
		return
	end

	if self._currentAnimTrack and self._currentAnimInstance and self._currentAnim ~= "" then
		self:_pushEvent("playAnimation", {
			animName = self._currentAnim,
			animId = self._currentAnimInstance.AnimationId,
			weightPool = self:_snapshotResolvedAnimationSets()[self._currentAnim] or { { id = self._currentAnimInstance.AnimationId, weight = 1 } },
			chosenWeight = 1,
			transitionTime = 0,
			speed = self._currentAnimSpeed,
			priority = priorityToName(self._currentAnimTrack.Priority),
			looped = self._currentAnimTrack.Looped or (self._emoteNames[self._currentAnim] == true),
		})
	end

	if self._toolAnimTrack and self._toolAnimInstance and self._currentToolAnimName ~= "" then
		self:_pushEvent("playToolAnimation", {
			animName = self._currentToolAnimName,
			animId = self._toolAnimInstance.AnimationId,
			weightPool = self:_snapshotResolvedAnimationSets()[self._currentToolAnimName] or { { id = self._toolAnimInstance.AnimationId, weight = 1 } },
			chosenWeight = 1,
			transitionTime = 0,
			priority = priorityToName(self._toolAnimTrack.Priority),
			speed = 1,
			signal = self._toolAnimSignal,
		})
	elseif self._toolAnimSignal ~= "None" then
		self:_pushEvent("tool_anim_signal", {
			value = self._toolAnimSignal,
		})
	end
end

function Recorder:_recordRootMotion(force: boolean?)
	if self._state ~= "recording" or self._playing then
		return
	end

	local rootCf = self:_getRootMotionCFrame()
	if not rootCf or not self:_hasRootMotionChanged(rootCf, force) then
		return
	end

	self:_pushEvent(ROOT_MOTION_KIND, encodeCFrame(rootCf))
	self._lastRecordedRootCFrame = rootCf
end

function Recorder:_getTrackSpeed(track: AnimationTrack?): number
	if not track then
		return 1
	end

	local ok, speed = pcall(function()
		return track.Speed
	end)
	if ok and typeof(speed) == "number" then
		return speed
	end

	return 1
end

function Recorder:_setToolAnimationSpeed(speed: number)
	if not self._toolAnimTrack then
		return
	end

	pcall(function()
		self._toolAnimTrack:AdjustSpeed(speed)
	end)
end

function Recorder:_seekTrackPosition(track: AnimationTrack?, position: number, allowLoop: boolean?)
	if not track then
		return
	end

	local targetPosition = math.max(0, position)
	local okLength, trackLength = pcall(function()
		return track.Length
	end)
	if okLength and typeof(trackLength) == "number" and trackLength > 0 then
		if allowLoop then
			targetPosition = targetPosition % trackLength
		else
			targetPosition = math.clamp(targetPosition, 0, math.max(trackLength - 0.001, 0))
		end
	end

	pcall(function()
		track.TimePosition = targetPosition
	end)
end

function Recorder:_seekTrackPositionDeferred(track: AnimationTrack?, position: number, allowLoop: boolean?, token: number)
	if not track then
		return
	end

	task.defer(function()
		if self._stopSeekToken ~= token or not self._stopActive then
			return
		end
		self:_seekTrackPosition(track, position, allowLoop)
		pcall(function()
			track:AdjustSpeed(0)
		end)
	end)
end

function Recorder:_sampleRootMotionAtTime(rootMotionEvents: { any }, elapsed: number): (CFrame?, number)
	local count = #rootMotionEvents
	if count <= 0 then
		return nil, 0
	end

	if count == 1 then
		return decodeCFrame(rootMotionEvents[1]), 1
	end

	local idx = 1
	while idx < count and elapsed > (tonumber(rootMotionEvents[idx + 1].t) or 0) do
		idx += 1
	end

	local currentFrame = rootMotionEvents[idx]
	local nextFrame = rootMotionEvents[math.min(idx + 1, count)]

	if idx >= count then
		return decodeCFrame(currentFrame), idx
	end

	local currentTime = tonumber(currentFrame.t) or 0
	local nextTime = tonumber(nextFrame.t) or currentTime

	if nextTime <= currentTime then
		return decodeCFrame(nextFrame), math.min(idx + 1, count)
	end

	local alpha = math.clamp((elapsed - currentTime) / (nextTime - currentTime), 0, 1)
	return decodeCFrame(currentFrame):Lerp(decodeCFrame(nextFrame), alpha), idx
end

function Recorder:_getSessionEndTime(session: any?): number
	if not session then
		return 0
	end

	local maxTime = 0
	for _, ev in ipairs(session.events or {}) do
		maxTime = math.max(maxTime, tonumber(ev.t) or 0)
	end
	for _, ev in ipairs(session.trace or {}) do
		maxTime = math.max(maxTime, tonumber(ev.t) or 0)
	end

	return maxTime
end

function Recorder:_truncateLiveSessionAtTime(cutoffTime: number)
	if not self._live then
		return
	end

	local trimmedEvents = {}
	local trimmedTrace = {}
	local epsilon = 0.000001
	local maxSeq = 0

	for _, ev in ipairs(self._live.events) do
		if (tonumber(ev.t) or 0) <= cutoffTime + epsilon then
			table.insert(trimmedEvents, ev)
			maxSeq = math.max(maxSeq, tonumber(ev.seq) or 0)
		end
	end

	for _, ev in ipairs(self._live.trace) do
		if (tonumber(ev.t) or 0) <= cutoffTime + epsilon then
			table.insert(trimmedTrace, ev)
			maxSeq = math.max(maxSeq, tonumber(ev.seq) or 0)
		end
	end

	self._live.events = trimmedEvents
	self._live.trace = trimmedTrace
	self._eventSeq = maxSeq

	local _, rootMotionEvents = self:_splitReplayEvents(self._live)
	local sampledRoot = self:_sampleRootMotionAtTime(rootMotionEvents, cutoffTime)
	if sampledRoot then
		self._lastRecordedRootCFrame = sampledRoot
	else
		self._lastRecordedRootCFrame = nil
	end
end

function Recorder:_updateStopPhysicsTarget(targetCFrame: CFrame)
	local mover = self._stopMover
	local rootPart = self._rootPart
	if not mover or not rootPart then
		return
	end

	local targetRootPartCFrame = self:_pivotToRootPartCFrame(targetCFrame)
	mover.alignPosition.Position = targetRootPartCFrame.Position
	mover.alignOrientation.CFrame = targetRootPartCFrame.Rotation
	mover.vectorForce.Force = Vector3.new(0, rootPart.AssemblyMass * Workspace.Gravity, 0)
end

function Recorder:_disableStopPhysics(restoreVelocity: boolean?)
	local mover = self._stopMover
	if not mover then
		return
	end

	local humanoid = mover.humanoid
	if humanoid and humanoid.Parent then
		humanoid.EvaluateStateMachine = mover.restoreEvaluateStateMachine
		humanoid.AutoRotate = mover.restoreAutoRotate
	end

	local rootPart = self._rootPart
	if rootPart and rootPart.Parent then
		if restoreVelocity then
			rootPart.AssemblyLinearVelocity = self._stopStoredLinearVelocity
			rootPart.AssemblyAngularVelocity = self._stopStoredAngularVelocity
		else
			rootPart.AssemblyLinearVelocity = Vector3.zero
			rootPart.AssemblyAngularVelocity = Vector3.zero
		end
	end

	local objects = {
		mover.vectorForce,
		mover.alignOrientation,
		mover.alignPosition,
		mover.attachment,
	}
	for _, obj in ipairs(objects) do
		if obj then
			obj:Destroy()
		end
	end

	self._stopMover = nil
end

function Recorder:_enableStopPhysics(initialCFrame: CFrame?)
	local humanoid = self._humanoid
	local rootPart = self._rootPart

	if not humanoid or not rootPart then
		return false
	end

	self:_disableStopPhysics(false)

	self._stopStoredLinearVelocity = rootPart.AssemblyLinearVelocity
	self._stopStoredAngularVelocity = rootPart.AssemblyAngularVelocity

	local attachment = Instance.new("Attachment")
	attachment.Name = "HumanoidAnimRecorderStopAttachment"
	attachment.Parent = rootPart

	local alignPosition = Instance.new("AlignPosition")
	alignPosition.Name = "HumanoidAnimRecorderStopAlignPosition"
	alignPosition.Attachment0 = attachment
	alignPosition.Mode = Enum.PositionAlignmentMode.OneAttachment
	alignPosition.ApplyAtCenterOfMass = true
	alignPosition.ReactionForceEnabled = false
	alignPosition.RigidityEnabled = false
	alignPosition.MaxForce = PLAYBACK_ALIGN_MAX_FORCE
	alignPosition.MaxVelocity = PLAYBACK_ALIGN_MAX_VELOCITY
	alignPosition.Responsiveness = PLAYBACK_ALIGN_RESPONSIVENESS
	local initialRootPartCFrame = self:_pivotToRootPartCFrame(initialCFrame or rootPart:GetPivot())
	alignPosition.Position = initialRootPartCFrame.Position
	alignPosition.Parent = rootPart

	local alignOrientation = Instance.new("AlignOrientation")
	alignOrientation.Name = "HumanoidAnimRecorderStopAlignOrientation"
	alignOrientation.Attachment0 = attachment
	alignOrientation.Mode = Enum.OrientationAlignmentMode.OneAttachment
	alignOrientation.ReactionTorqueEnabled = false
	alignOrientation.RigidityEnabled = false
	alignOrientation.MaxTorque = PLAYBACK_ALIGN_MAX_TORQUE
	alignOrientation.MaxAngularVelocity = PLAYBACK_ALIGN_MAX_ANGULAR_VELOCITY
	alignOrientation.Responsiveness = PLAYBACK_ALIGN_RESPONSIVENESS
	alignOrientation.CFrame = initialRootPartCFrame.Rotation
	alignOrientation.Parent = rootPart

	local vectorForce = Instance.new("VectorForce")
	vectorForce.Name = "HumanoidAnimRecorderStopVectorForce"
	vectorForce.Attachment0 = attachment
	vectorForce.RelativeTo = Enum.ActuatorRelativeTo.World
	vectorForce.ApplyAtCenterOfMass = true
	vectorForce.Force = Vector3.new(0, rootPart.AssemblyMass * Workspace.Gravity, 0)
	vectorForce.Parent = rootPart

	local restoreEvaluateStateMachine = humanoid.EvaluateStateMachine
	local restoreAutoRotate = humanoid.AutoRotate

	humanoid.EvaluateStateMachine = false
	humanoid.AutoRotate = false

	rootPart.AssemblyLinearVelocity = Vector3.zero
	rootPart.AssemblyAngularVelocity = Vector3.zero

	self._stopMover = {
		humanoid = humanoid,
		restoreEvaluateStateMachine = restoreEvaluateStateMachine,
		restoreAutoRotate = restoreAutoRotate,
		attachment = attachment,
		alignPosition = alignPosition,
		alignOrientation = alignOrientation,
		vectorForce = vectorForce,
	}

	return true
end

function Recorder:_applyStopPreview(targetTime: number): boolean
	if not self._live or not self._humanoid then
		return false
	end

	local replayEvents, rootMotionEvents = self:_splitReplayEvents(self._live)
	local sessionEndTime = self:_getSessionEndTime(self._live)
	targetTime = math.clamp(targetTime, 0, sessionEndTime)

	self._stopSeekToken += 1
	local stopSeekToken = self._stopSeekToken

	self:_stopAllAnimations(true, 0)
	self:_stopToolAnimations(true)
	self._toolAnimSignal = "None"
	self._pose = "Standing"
	self._currentAnimSpeed = 1.0

	local mainState = {
		track = nil,
		speed = 1.0,
		position = 0.0,
		lastTime = 0.0,
		allowLoop = false,
	}
	local toolState = {
		track = nil,
		speed = 1.0,
		position = 0.0,
		lastTime = 0.0,
		allowLoop = false,
	}

	local function advanceState(stateTable, untilTime)
		if not stateTable.track then
			return
		end
		local delta = math.max(0, untilTime - (stateTable.lastTime or 0))
		stateTable.position += delta * (stateTable.speed or 1)
		stateTable.lastTime = untilTime
	end

	for _, ev in ipairs(replayEvents) do
		local evTime = tonumber(ev.t) or 0
		if evTime > targetTime then
			break
		end

		local kind = ev.kind
		if kind == "session_start" then
			self._pose = ev.initialPose or "Standing"

		elseif kind == "pose" then
			self._pose = ev.value or self._pose

		elseif kind == "playAnimation" then
			local track = self:_playAnimation(
				ev.animName or "idle",
				tonumber(ev.transitionTime) or 0,
				self._humanoid :: Humanoid,
				ev.animId,
				true
			)
			mainState.track = track
			mainState.speed = tonumber(ev.speed) or 1
			mainState.position = 0
			mainState.lastTime = evTime
			mainState.allowLoop = ev.looped == true
			if track then
				pcall(function()
					track:AdjustSpeed(0)
				end)
			end

		elseif kind == "speed" then
			if ev.target == "main" then
				advanceState(mainState, evTime)
				mainState.speed = tonumber(ev.value) or 1
				self:_setAnimationSpeed(mainState.speed, true)
			end

		elseif kind == "stopAnimation" then
			advanceState(mainState, evTime)
			self:_stopAllAnimations(true, tonumber(ev.transitionTime) or 0)
			mainState.track = nil

		elseif kind == "playToolAnimation" then
			self._toolAnimSignal = ev.signal or self._toolAnimSignal
			local track = self:_playToolAnimation(
				ev.animName or "toolnone",
				tonumber(ev.transitionTime) or 0,
				self._humanoid :: Humanoid,
				self:_parsePriority(ev.priority),
				ev.animId,
				true
			)
			toolState.track = track
			toolState.speed = tonumber(ev.speed) or 1
			toolState.position = 0
			toolState.lastTime = evTime
			toolState.allowLoop = false
			if track then
				pcall(function()
					track:AdjustSpeed(0)
				end)
			end

		elseif kind == "stopToolAnimation" then
			advanceState(toolState, evTime)
			self:_stopToolAnimations(true)
			toolState.track = nil

		elseif kind == "tool_anim_signal" then
			self._toolAnimSignal = ev.value or "None"
		end
	end

	advanceState(mainState, targetTime)
	advanceState(toolState, targetTime)

	if mainState.track then
		self:_seekTrackPosition(mainState.track, mainState.position, mainState.allowLoop)
		self:_seekTrackPositionDeferred(mainState.track, mainState.position, mainState.allowLoop, stopSeekToken)
	end
	if toolState.track then
		self:_seekTrackPosition(toolState.track, toolState.position, toolState.allowLoop)
		self:_seekTrackPositionDeferred(toolState.track, toolState.position, toolState.allowLoop, stopSeekToken)
	end

	self._stopStoredMainSpeed = mainState.track and mainState.speed or self._currentAnimSpeed
	self._stopStoredToolSpeed = toolState.track and toolState.speed or self:_getTrackSpeed(self._toolAnimTrack)
	self._currentAnimSpeed = self._stopStoredMainSpeed

	if self._currentAnimTrack then
		self._currentAnimTrack:AdjustSpeed(0)
	end
	if self._toolAnimTrack then
		self._toolAnimTrack:AdjustSpeed(0)
	end

	local sampledRoot, rootFrame = self:_sampleRootMotionAtTime(rootMotionEvents, targetTime)
	if sampledRoot then
		self:_applyImmediateRootMotion(sampledRoot, true)
		self:_updateStopPhysicsTarget(sampledRoot)
		self._lastRecordedRootCFrame = sampledRoot
		self._stopStoredLinearVelocity, self._stopStoredAngularVelocity = self:_estimateRootMotionVelocityAtTime(rootMotionEvents, targetTime)
		self._stopPreviewFrame = math.max(rootFrame, 1)
	else
		self._stopStoredLinearVelocity = Vector3.zero
		self._stopStoredAngularVelocity = Vector3.zero
		self._stopPreviewFrame = 1
	end

	self._stopPreviewTime = targetTime
	self._stopResumeTruncateTime = targetTime
	return true
end

function Recorder:_enterStopMode()
	if self._state ~= "recording" or not self._live then
		return false, "not_recording"
	end
	if self._stopActive then
		return false, "already_stopped"
	end

	local currentTime = math.max(0, os.clock() - self._recordStartClock)
	self:_recordRootMotion(true)
	if self._live then
		currentTime = math.max(currentTime, self:_getSessionEndTime(self._live))
	end
	self:_pushTrace("stop_enabled", {
		frame = self._stopPreviewFrame,
		t = currentTime,
	})

	local currentRoot = self:_getRootMotionCFrame()
	if currentRoot then
		local enabled = self:_enableStopPhysics(currentRoot)
		if not enabled then
			return false, "stop_physics_failed"
		end
		self:_updateStopPhysicsTarget(currentRoot)
	end

	self._stopStoredMainSpeed = self._currentAnimSpeed
	self._stopStoredToolSpeed = self:_getTrackSpeed(self._toolAnimTrack)

	if self._currentAnimTrack then
		self._currentAnimTrack:AdjustSpeed(0)
	end
	if self._toolAnimTrack then
		self._toolAnimTrack:AdjustSpeed(0)
	end

	self._stopActive = true
	self._stopPreviewTime = currentTime
	self._stopResumeTruncateTime = currentTime
	local _, rootMotionEvents = self:_splitReplayEvents(self._live)
	local _, frameIndex = self:_sampleRootMotionAtTime(rootMotionEvents, currentTime)
	self._stopPreviewFrame = math.max(frameIndex, 1)
	self:_setState("stopped")
	return true
end

function Recorder:_exitStopMode()
	if self._state ~= "stopped" or not self._stopActive then
		return false, "stop_not_active"
	end

	local resumeTime = self._stopResumeTruncateTime or self._stopPreviewTime or 0
	self:_truncateLiveSessionAtTime(resumeTime)
	self._savedSession = nil
	self._savedDecoded = nil
	self._recordStartClock = os.clock() - resumeTime
	self._rootSampleAccumulator = 0
	self._lastRecordedRootCFrame = nil

	self:_disableStopPhysics(true)
	self._stopActive = false
	self:_setState("recording")

	if self._currentAnimTrack then
		self._currentAnimTrack:AdjustSpeed(self._stopStoredMainSpeed)
		self._currentAnimSpeed = self._stopStoredMainSpeed
	end
	if self._toolAnimTrack then
		self._toolAnimTrack:AdjustSpeed(self._stopStoredToolSpeed)
	end

	self:_recordRootMotion(true)
	self:_pushTrace("stop_disabled", {
		frame = self._stopPreviewFrame,
		t = resumeTime,
	})

	return true
end

function Recorder:_getStopTargetTimeByFrame(delta: number): (number?, number?, string?)
	if not self._live then
		return nil, nil, "no_recording_data"
	end

	local _, rootMotionEvents = self:_splitReplayEvents(self._live)
	local count = #rootMotionEvents
	if count <= 0 then
		return nil, nil, "no_recording_data"
	end

	local currentFrame = math.clamp(self._stopPreviewFrame or 1, 1, count)
	if delta == 0 then
		return nil, nil, "no_frame_change"
	end

	local unclampedTarget = currentFrame + delta
	local nextFrame = math.clamp(unclampedTarget, 1, count)
	if nextFrame == currentFrame then
		if currentFrame <= 1 and delta < 0 then
			return nil, nil, "at_first_frame"
		end
		if currentFrame >= count and delta > 0 then
			return nil, nil, "at_last_frame"
		end
		return nil, nil, "no_frame_change"
	end

	local ev = rootMotionEvents[nextFrame]
	if not ev then
		return nil, nil, "no_recording_data"
	end

	return tonumber(ev.t) or 0, nextFrame, nil
end

function Recorder:_goStopFrame(delta: number)
	if self._state ~= "stopped" or not self._stopActive then
		return false, "stop_not_active"
	end

	local targetTime, targetFrame, reason = self:_getStopTargetTimeByFrame(delta)
	if targetTime == nil or targetFrame == nil then
		return false, reason or "no_recording_data"
	end

	local ok = self:_applyStopPreview(targetTime)
	if not ok then
		return false, "preview_failed"
	end

	self._stopPreviewFrame = targetFrame
	self._stopResumeTruncateTime = targetTime
	return true, targetFrame
end

function Recorder:_disablePlaybackPhysics()
	local mover = self._playbackMover
	if not mover then
		return
	end

	local humanoid = mover.humanoid
	if humanoid and humanoid.Parent then
		humanoid.EvaluateStateMachine = mover.restoreEvaluateStateMachine
		humanoid.AutoRotate = mover.restoreAutoRotate
	end

	for part, oldCanCollide in pairs(mover.collisions) do
		if part and part.Parent then
			part.CanCollide = oldCanCollide
		end
	end

	if self._rootPart and self._rootPart.Parent then
		self._rootPart.AssemblyLinearVelocity = Vector3.zero
		self._rootPart.AssemblyAngularVelocity = Vector3.zero
	end

	local objects = {
		mover.vectorForce,
		mover.alignOrientation,
		mover.alignPosition,
		mover.attachment,
	}
	for _, obj in ipairs(objects) do
		if obj then
			obj:Destroy()
		end
	end

	self._playbackMover = nil
	self._playbackMotionIndex = 1
end

function Recorder:_enablePlaybackPhysics(initialCFrame: CFrame?)
	local humanoid = self._humanoid
	local rootPart = self._rootPart

	if not humanoid or not rootPart then
		return false
	end

	self:_disablePlaybackPhysics()

	local collisions = {}
	for _, descendant in ipairs((self._character :: Model):GetDescendants()) do
		if descendant:IsA("BasePart") then
			collisions[descendant] = descendant.CanCollide
			descendant.CanCollide = false
		end
	end

	local attachment = Instance.new("Attachment")
	attachment.Name = "HumanoidAnimRecorderPlaybackAttachment"
	attachment.Parent = rootPart

	local alignPosition = Instance.new("AlignPosition")
	alignPosition.Name = "HumanoidAnimRecorderAlignPosition"
	alignPosition.Attachment0 = attachment
	alignPosition.Mode = Enum.PositionAlignmentMode.OneAttachment
	alignPosition.ApplyAtCenterOfMass = true
	alignPosition.ReactionForceEnabled = false
	alignPosition.RigidityEnabled = false
	alignPosition.MaxForce = PLAYBACK_ALIGN_MAX_FORCE
	alignPosition.MaxVelocity = PLAYBACK_ALIGN_MAX_VELOCITY
	alignPosition.Responsiveness = PLAYBACK_ALIGN_RESPONSIVENESS
	local initialRootPartCFrame = self:_pivotToRootPartCFrame(initialCFrame or rootPart:GetPivot())
	alignPosition.Position = initialRootPartCFrame.Position
	alignPosition.Parent = rootPart

	local alignOrientation = Instance.new("AlignOrientation")
	alignOrientation.Name = "HumanoidAnimRecorderAlignOrientation"
	alignOrientation.Attachment0 = attachment
	alignOrientation.Mode = Enum.OrientationAlignmentMode.OneAttachment
	alignOrientation.ReactionTorqueEnabled = false
	alignOrientation.RigidityEnabled = false
	alignOrientation.MaxTorque = PLAYBACK_ALIGN_MAX_TORQUE
	alignOrientation.MaxAngularVelocity = PLAYBACK_ALIGN_MAX_ANGULAR_VELOCITY
	alignOrientation.Responsiveness = PLAYBACK_ALIGN_RESPONSIVENESS
	alignOrientation.CFrame = initialRootPartCFrame.Rotation
	alignOrientation.Parent = rootPart

	local vectorForce = Instance.new("VectorForce")
	vectorForce.Name = "HumanoidAnimRecorderVectorForce"
	vectorForce.Attachment0 = attachment
	vectorForce.RelativeTo = Enum.ActuatorRelativeTo.World
	vectorForce.ApplyAtCenterOfMass = true
	vectorForce.Force = Vector3.new(0, rootPart.AssemblyMass * Workspace.Gravity, 0)
	vectorForce.Parent = rootPart

	local restoreEvaluateStateMachine = humanoid.EvaluateStateMachine
	local restoreAutoRotate = humanoid.AutoRotate

	humanoid.EvaluateStateMachine = false
	humanoid.AutoRotate = false

	rootPart.AssemblyLinearVelocity = Vector3.zero
	rootPart.AssemblyAngularVelocity = Vector3.zero

	self._playbackMover = {
		humanoid = humanoid,
		restoreEvaluateStateMachine = restoreEvaluateStateMachine,
		restoreAutoRotate = restoreAutoRotate,
		collisions = collisions,
		attachment = attachment,
		alignPosition = alignPosition,
		alignOrientation = alignOrientation,
		vectorForce = vectorForce,
	}

	return true
end

function Recorder:_splitReplayEvents(session: any): ({ any }, { any })
	local replayEvents = {}
	local rootMotionEvents = {}

	for _, ev in ipairs(session.events or {}) do
		if ev.kind == ROOT_MOTION_KIND then
			table.insert(rootMotionEvents, ev)
		else
			table.insert(replayEvents, ev)
		end
	end

	return replayEvents, rootMotionEvents
end

function Recorder:_sampleRootMotion(rootMotionEvents: { any }, elapsed: number): CFrame?
	local count = #rootMotionEvents
	if count <= 0 then
		return nil
	end

	if count == 1 then
		return decodeCFrame(rootMotionEvents[1])
	end

	local idx = self._playbackMotionIndex
	if idx < 1 then
		idx = 1
	elseif idx > count then
		idx = count
	end

	while idx < count and elapsed > (tonumber(rootMotionEvents[idx + 1].t) or 0) do
		idx += 1
	end
	self._playbackMotionIndex = idx

	local currentFrame = rootMotionEvents[idx]
	local nextFrame = rootMotionEvents[math.min(idx + 1, count)]

	if idx >= count then
		return decodeCFrame(currentFrame)
	end

	local currentTime = tonumber(currentFrame.t) or 0
	local nextTime = tonumber(nextFrame.t) or currentTime

	if nextTime <= currentTime then
		return decodeCFrame(nextFrame)
	end

	local alpha = math.clamp((elapsed - currentTime) / (nextTime - currentTime), 0, 1)
	return decodeCFrame(currentFrame):Lerp(decodeCFrame(nextFrame), alpha)
end

function Recorder:_applyPlaybackRootMotion(targetCFrame: CFrame)
	local mover = self._playbackMover
	local rootPart = self._rootPart
	if not mover or not rootPart then
		return
	end

	local targetRootPartCFrame = self:_pivotToRootPartCFrame(targetCFrame)
	mover.alignPosition.Position = targetRootPartCFrame.Position
	mover.alignOrientation.CFrame = targetRootPartCFrame.Rotation
	mover.vectorForce.Force = Vector3.new(0, rootPart.AssemblyMass * Workspace.Gravity, 0)
end

function Recorder:_onRunning(speed: number)
	if self:_isRuntimeSuppressed() or not self._humanoid then
		return
	end

	self:_traceHumanoidSignal("Running", { speed = speed })

	speed /= self:_getRigScale()

	if speed > 0.01 then
		self:_playAnimation("walk", 0.1, self._humanoid)
		if self._currentAnimInstance and self._currentAnimInstance.AnimationId == "http://www.roblox.com/asset/?id=180426354" then
			self:_setAnimationSpeed(speed / 14.5)
		end
		self:_setPose("Running", { value = "Running", speed = speed })
	else
		if self._emoteNames[self._currentAnim] == nil then
			self:_playAnimation("idle", 0.1, self._humanoid)
			self:_setPose("Standing", { value = "Standing", speed = speed })
		end
	end
end

function Recorder:_onDied()
	if self:_isRuntimeSuppressed() then
		return
	end

	self:_traceHumanoidSignal("Died", {})
	self:_setPose("Dead", { value = "Dead" })
